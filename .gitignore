/lib/l10n/app_localizations_en.dart

# Codex / agent local artifacts
.agents/
.codex
.codex/
/tooling/

# Local Flutter tool metadata (project-scoped)
.metadata

# Test & coverage artifacts
coverage/

# Temporary / patch leftovers
*.orig
*.rej
